# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role key: server-side only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Shared secret for the /admin dashboard login.
ADMIN_PASSWORD=change-me

# Email delivery (https://resend.com). Without a key, emails are written
# to .dev-data/outbox/ instead of being sent (dev only).
RESEND_API_KEY=
# Verified sender, e.g. "KLFW 2026 <tickets@yourdomain.com>"
EMAIL_FROM=

# WhatsApp delivery (https://wablas.com). Both are required; find them in
# your Wablas dashboard after connecting a device (scan the QR code there).
# Without them, messages are written to .dev-data/outbox-wa/ (dev only).
WABLAS_BASE_URL=
WABLAS_TOKEN=
# Only needed if "secret key" security is enabled on the Wablas device.
WABLAS_SECRET_KEY=

# Public base URL of the deployed app, used in email and WhatsApp links.
APP_URL=http://localhost:3000
