# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role key: server-side only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Shared secret for the /admin dashboard login.
ADMIN_PASSWORD=change-me

# Email delivery (https://resend.com). Without a key, emails are written
# to .dev-data/outbox/ instead of being sent (dev only).
RESEND_API_KEY=
# Verified sender, e.g. "KLFW 2026 <tickets@yourdomain.com>"
EMAIL_FROM=
# Public base URL of the deployed app, used in email links.
APP_URL=http://localhost:3000
